@{
    ViewData["Title"] = "My Schedule";
    Layout = "_Layout";
}

<div class="schedule-page">
    <div class="schedule-bg"></div>
    <div class="schedule-content">
        <h1 class="schedule-title">Schedule</h1>

        <div class="schedule-grid">

            <!-- MONDAY -->
            <div class="day-column">
                <h2 class="day-label">Monday</h2>
                <div class="day-card">
                    <div class="subject-block">
                        <span class="subject-name">ETHICS</span>
                        <span class="subject-time">1:30 PM – 4:30 PM</span>
                    </div>
                    <div class="subject-block">
                        <span class="subject-name">DATA MINING</span>
                        <span class="subject-time">4:30 PM – 6:00 PM</span>
                    </div>
                    <div class="subject-block">
                        <span class="subject-name">IAS</span>
                        <span class="subject-time">6:00 PM – 9:00 PM</span>
                    </div>
                </div>
            </div>

            <!-- TUESDAY -->
            <div class="day-column">
                <h2 class="day-label">Tuesday</h2>
                <div class="day-card">
                    <div class="subject-block">
                        <span class="subject-name">TCW</span>
                        <span class="subject-time">10:30 AM – 1:30 PM</span>
                    </div>
                    <div class="subject-block">
                        <span class="subject-name">ADET</span>
                        <span class="subject-time">7:00 PM – 9:00 PM</span>
                    </div>
                </div>
            </div>

            <!-- THURSDAY -->
            <div class="day-column">
                <h2 class="day-label">Thursday</h2>
                <div class="day-card">
                    <div class="subject-block">
                        <span class="subject-name">IAS</span>
                        <span class="subject-time">10:30 AM – 1:30 PM</span>
                    </div>
                    <div class="subject-block">
                        <span class="subject-name">DATA MINING</span>
                        <span class="subject-time">4:30 PM – 8:30 PM</span>
                    </div>
                </div>
            </div>

            <!-- FRIDAY -->
            <div class="day-column">
                <h2 class="day-label">Friday</h2>
                <div class="day-card">
                    <div class="subject-block">
                        <span class="subject-name">POM</span>
                        <span class="subject-time">10:30 AM – 1:30 PM</span>
                    </div>
                    <div class="subject-block">
                        <span class="subject-name">CAPSTONE</span>
                        <span class="subject-time">4:00 PM – 9:00 PM</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
